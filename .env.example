# Modelo de variaveis de ambiente (versionado, sem valores reais).
# Copie para .env e preencha para rodar o worker localmente.
#
# Escopo:
#   VITE_SUPABASE_URL          publica (front + worker). Pode ir no cliente.
#   SUPABASE_SERVICE_ROLE_KEY  SEGREDO. So no worker (netlify/functions). Ignora RLS.
#   EIA_API_KEY                SEGREDO. So no worker.
#   BRAPI_TOKEN                SEGREDO. So no worker (plano Pro).
#
# Em producao, estas variaveis ja estao no painel do Netlify (escopo Functions).

VITE_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EIA_API_KEY=
BRAPI_TOKEN=
